PORT=3001
# ── LLM Provider ──
# Options: groq (free, default), ollama (local), anthropic (production)
LLM_PROVIDER=grok
# ── Grok / xAI (default) ──
GROK_API_KEY=your_xai_key           # Get keys at https://console.x.ai
# GROK_API_KEYS=key1,key2,key3     # Multiple keys for round-robin (overrides GROK_API_KEY)
# GROK_MODEL=grok-3-mini           # Default: grok-3-mini
# ── Groq (alternative, free) ──
# LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_key          # Free at https://console.groq.com
# GROQ_API_KEYS=key1,key2,key3     # Multiple keys for round-robin (overrides GROQ_API_KEY)
# ANTHROPIC_API_KEY=your_key_here   # Only if LLM_PROVIDER=anthropic
OLLAMA_MODEL=llama3.1                # Only if LLM_PROVIDER=ollama

TELEGRAM_BOT_TOKEN=your_bot_token_here
COINGECKO_API_URL=https://api.coingecko.com/api/v3
PROTOCOL_WALLET=your_ton_wallet_address_here
TOKEN_CONTRACT=your_jetton_master_address_here
TOKEN_SYMBOL=BXC
TOKEN_NAME=Blockixchainix
PROTOCOL_FEE_BPS=500
BOT_NOTIFICATION_URL=http://localhost:3002
